---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

function getReadingTime(text: string): string {
  const words = text.trim().split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min de leitura`;
}

const articles = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="IA Primeiros Passos"
  description="Inteligência artificial explicada de um jeito que qualquer pessoa entende. Sem jargão técnico, com exemplos do dia a dia."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-container">
      <div class="hero-badge">
        <span>✦</span> Para quem está começando
      </div>
      <h1 class="hero-title">
        Entenda IA do jeito<br />
        <span class="hero-highlight">que faz sentido</span>
      </h1>
      <p class="hero-description">
        Inteligência Artificial explicada com linguagem simples,
        exemplos do dia a dia e zero jargão técnico.
        Aqui você aprende de verdade.
      </p>
      <a href="#artigos" class="hero-cta">
        Ver artigos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </a>
    </div>

    <div class="hero-decoration" aria-hidden="true">
      <div class="deco-circle deco-circle-1"></div>
      <div class="deco-circle deco-circle-2"></div>
    </div>
  </section>

  <!-- Articles section -->
  <section class="articles-section" id="artigos">
    <div class="section-container">
      <div class="section-header">
        <h2 class="section-title">Artigos recentes</h2>
        <p class="section-subtitle">
          {articles.length} {articles.length === 1 ? 'artigo publicado' : 'artigos publicados'}
        </p>
      </div>

      {articles.length === 0 ? (
        <div class="empty-state">
          <p>Novos artigos em breve. Volte logo!</p>
        </div>
      ) : (
        <div class="articles-grid">
          {articles.map(article => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              pubDate={article.data.pubDate}
              tags={article.data.tags}
              author={article.data.author}
              readingTime={getReadingTime(article.body)}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- CTA section -->
  <section class="cta-section">
    <div class="cta-container">
      <div class="cta-card">
        <h2>Gostou do conteúdo?</h2>
        <p>
          Compartilhe este blog com amigos e familiares que querem entender
          o mundo da inteligência artificial sem complicação.
        </p>
        <a
          href={`https://api.whatsapp.com/send?text=Encontrei esse blog incrível sobre IA para iniciantes: https://ia-primeiros-passos.vercel.app`}
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button"
        >
          Compartilhar no WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #faf5ff 0%, #f0f9ff 100%);
    border-bottom: 1px solid var(--color-border);
    padding: 5rem 1.5rem 6rem;
  }

  .hero-container {
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: 0.375rem 0.875rem;
    border-radius: 99px;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    max-width: 16ch;
  }

  .hero-highlight {
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 1.1875rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin-bottom: 2.25rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: background-color 0.15s, transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 14px rgba(124, 58, 237, 0.35);
  }

  .hero-cta:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
    color: white;
  }

  .hero-cta svg {
    transition: transform 0.2s;
  }

  .hero-cta:hover svg {
    transform: translateY(2px);
  }

  /* Decorative circles */
  .hero-decoration {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .deco-circle {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.08) 0%, transparent 70%);
  }

  .deco-circle-1 {
    width: 600px;
    height: 600px;
    right: -150px;
    top: -150px;
  }

  .deco-circle-2 {
    width: 400px;
    height: 400px;
    left: -100px;
    bottom: -200px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.06) 0%, transparent 70%);
  }

  /* ── Articles section ── */
  .articles-section {
    padding: 4rem 1.5rem;
  }

  .section-container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.625rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-muted);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px dashed var(--color-border);
  }

  /* ── CTA section ── */
  .cta-section {
    padding: 0 1.5rem 5rem;
  }

  .cta-container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .cta-card {
    background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
    border-radius: var(--radius-lg);
    padding: 3rem;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .cta-card h2 {
    font-size: 1.625rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .cta-card p {
    font-size: 1rem;
    line-height: 1.65;
    opacity: 0.9;
    max-width: 50ch;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: var(--color-primary);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: opacity 0.15s, transform 0.15s;
  }

  .cta-button:hover {
    opacity: 0.92;
    transform: translateY(-1px);
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3.5rem 1.5rem 4.5rem;
    }

    .cta-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
